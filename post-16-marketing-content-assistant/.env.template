# Mode 2 - Direct to provider: https://api.deepseek.com/v1 or https://generativelanguage.googleapis.com/v1beta
# If using Mode 2, set LITELLM_API_KEY to the provider's API key directly.

LITELLM_BASE_URL=http://localhost:4000
MODEL_NAME=YOUR_MODEL_NAME_HERE
LITELLM_API_KEY=YOUR_API_KEY_HERE

PRODUCT_NAME=YOUR_PRODUCT_NAME_HERE
PRODUCT_DESCRIPTION=YOUR_PRODUCT_DESCRIPTION_HERE
TARGET_AUDIENCE=YOUR_TARGET_AUDIENCE_HERE

FORBIDDEN_WORDS=cheap,free trial,cheaper,best-in-class,industry-leading
BRAND_TONE=authoritative but friendly
MAX_EDITOR_RETRIES=3
